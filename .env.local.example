# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# --- Firebase CLIENT config ---
# From Firebase Console → Project Settings → General → Your apps → Web app config.
# These are safe to expose to the browser (that's what NEXT_PUBLIC_ means) — Firebase
# client keys are not secret, access control happens via Firestore security rules.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase ADMIN config (server-side only, keep secret) ---
# From Firebase Console → Project Settings → Service Accounts → Generate new private key.
# That downloads a JSON file. Copy the three fields below out of it.
# IMPORTANT: paste the private_key value exactly, keeping it wrapped in quotes —
# it contains literal \n characters that need to stay intact.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=""

# Secret used to authorize the one-off scripts/createClinic.mjs bootstrap script.
# Make up any long random string. Only needed locally, never deployed.
SETUP_SECRET=
