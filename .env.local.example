# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# --- Firebase CLIENT config ---
# From Firebase Console → Project Settings → General → Your apps → Web app config.
# These are safe to expose to the browser (that's what NEXT_PUBLIC_ means) — Firebase
# client keys are not secret, access control happens via Firestore security rules.
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyCDAZrX3ZWXae4bIj5vsCbHt5wK1Djta64
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=radiancelaser-c9bd4.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=radiancelaser-c9bd4
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=radiancelaser-c9bd4.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1035339144812
NEXT_PUBLIC_FIREBASE_APP_ID=1:1035339144812:web:7ffb7d18cd73a444638249

