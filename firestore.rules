rules_version = '2';

// Multi-tenant isolation model:
// - Every user's Firebase Auth token carries custom claims: clinicId + role
//   (set server-side in scripts/createClinic.mjs — never trust claims a
//   client could set themselves).
// - Every data document (appointments, patients, etc.) stores a clinicId
//   field matching the clinic it belongs to.
// - Every rule below checks that the requester's token clinicId matches the
//   document's clinicId, so one clinic's staff can never read or write
//   another clinic's data, even if they guessed a document ID.
//
// Deploy with: firebase deploy --only firestore:rules

function isSignedIn() {
  return request.auth != null;
}

function clinicId() {
  return request.auth.token.clinicId;
}

function belongsToClinic(data) {
  return isSignedIn() && data.clinicId == clinicId();
}

service cloud.firestore {
  match /databases/{database}/documents {

    // The clinic's own profile doc — readable by its own staff, not writable
    // by clients at all (only the Admin SDK / server should update this).
    match /clinics/{clinicId} {
      allow read: if isSignedIn() && request.auth.token.clinicId == clinicId;
      allow write: if false;
    }

    // Every tenant-scoped collection follows the same pattern. Add more
    // collections here as the product grows — each one just needs a
    // clinicId field on its documents and this same rule shape.
    //
    // NOTE on delete: request.resource doesn't exist for a delete operation
    // (there's no new document being written), so a delete rule can only
    // check resource.data (the document as it existed before removal) — not
    // request.resource.data. Checking request.resource.data on delete always
    // evaluates to false, silently blocking every delete. Keep update and
    // delete as separate allow statements, not combined, to avoid this.
    match /appointments/{appointmentId} {
      allow read: if belongsToClinic(resource.data);
      allow create: if belongsToClinic(request.resource.data);
      allow update: if belongsToClinic(resource.data)
        && belongsToClinic(request.resource.data); // can't change clinicId on update
      allow delete: if belongsToClinic(resource.data);
    }

    match /patients/{patientId} {
      allow read: if belongsToClinic(resource.data);
      allow create: if belongsToClinic(request.resource.data);
      allow update: if belongsToClinic(resource.data)
        && belongsToClinic(request.resource.data);
      allow delete: if belongsToClinic(resource.data);
    }

    match /visits/{visitId} {
      allow read: if belongsToClinic(resource.data);
      allow create: if belongsToClinic(request.resource.data);
      allow update: if belongsToClinic(resource.data)
        && belongsToClinic(request.resource.data);
      allow delete: if belongsToClinic(resource.data);
    }

    match /packages/{packageId} {
      allow read: if belongsToClinic(resource.data);
      allow create: if belongsToClinic(request.resource.data);
      allow update: if belongsToClinic(resource.data)
        && belongsToClinic(request.resource.data);
      allow delete: if belongsToClinic(resource.data);
    }

    match /counters/{counterId} {
      allow read: if belongsToClinic(resource.data);
      allow write: if belongsToClinic(request.resource.data);
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
