rules_version = '2';

// Multi-tenant isolation model:
// - Every user's Firebase Auth token carries custom claims: clinicId + role
//   (set server-side in scripts/createClinic.mjs — never trust claims a
//   client could set themselves).
// - Every data document (appointments, patients, etc.) stores a clinicId
//   field matching the clinic it belongs to.
// - Every rule below checks that the requester's token clinicId matches the
//   document's clinicId, so one clinic's staff can never read or write
//   another clinic's data, even if they guessed a document ID.
//
// Deploy with: firebase deploy --only firestore:rules

function isSignedIn() {
  return request.auth != null;
}

function clinicId() {
  return request.auth.token.clinicId;
}

function belongsToClinic(data) {
  return isSignedIn() && data.clinicId == clinicId();
}

service cloud.firestore {
  match /databases/{database}/documents {

    // The clinic's own profile doc — readable by its own staff, not writable
    // by clients at all (only the Admin SDK / server should update this).
    match /clinics/{clinicId} {
      allow read: if isSignedIn() && request.auth.token.clinicId == clinicId;
      allow write: if false;
    }

    // Every tenant-scoped collection follows the same pattern. Add more
    // collections here as the product grows — each one just needs a
    // clinicId field on its documents and this same rule shape.
    //
    // NOTE on delete: request.resource doesn't exist for a delete operation
    // (there's no new document being written), so a delete rule can only
    // check resource.data (the document as it existed before removal) — not
    // request.resource.data. Checking request.resource.data on delete always
    // evaluates to false, silently blocking every delete. Keep update and
    // delete as separate allow statements, not combined, to avoid this.
    match /appointments/{appointmentId} {
      allow read: if belongsToClinic(resource.data);
      allow create: if belongsToClinic(request.resource.data);
      allow update: if belongsToClinic(resource.data)
        && belongsToClinic(request.resource.data); // can't change clinicId on update
      allow delete: if belongsToClinic(resource.data);
    }

    match /patients/{patientId} {
      allow read: if belongsToClinic(resource.data);
      allow create: if belongsToClinic(request.resource.data);
      allow update: if belongsToClinic(resource.data)
        && belongsToClinic(request.resource.data);
      allow delete: if belongsToClinic(resource.data);
    }

    match /visits/{visitId} {
      allow read: if belongsToClinic(resource.data);
      allow create: if belongsToClinic(request.resource.data);
      allow update: if belongsToClinic(resource.data)
        && belongsToClinic(request.resource.data);
      allow delete: if belongsToClinic(resource.data);
    }

    match /packages/{packageId} {
      allow read: if belongsToClinic(resource.data);
      allow create: if belongsToClinic(request.resource.data);
      allow update: if belongsToClinic(resource.data)
        && belongsToClinic(request.resource.data);
      allow delete: if belongsToClinic(resource.data);
    }

    match /counters/{counterId} {
      // resource == null when the counter doc doesn't exist yet (e.g. the
      // very first receipt a clinic ever issues) — without this check,
      // resource.data on a nonexistent doc throws and the read is denied,
      // which aborts the allocateReceiptNumber() transaction in
      // lib/receiptNumber.ts before it ever gets to create the doc. Safe to
      // allow: a nonexistent doc has no data to protect, and counter IDs are
      // derived from the caller's own clinicId anyway.
      allow read: if resource == null || belongsToClinic(resource.data);
      allow write: if belongsToClinic(request.resource.data);
    }

    // Firestore mirror of Firebase Auth users (see app/dashboard/settings/actions.ts).
    // Deliberately read-only for clients — staff are added/edited/removed
    // only through server actions using the Admin SDK, which bypasses these
    // rules entirely. A client should never be able to grant itself a role
    // by writing directly to this collection.
    match /staff/{staffId} {
      allow read: if belongsToClinic(resource.data);
      allow write: if false;
    }

    match /machines/{machineId} {
      allow read: if belongsToClinic(resource.data);
      allow create: if belongsToClinic(request.resource.data);
      allow update: if belongsToClinic(resource.data)
        && belongsToClinic(request.resource.data);
      allow delete: if belongsToClinic(resource.data);
    }

    // Clinic-defined major machine types (e.g. "CO2 Laser"), on top of the
    // built-in Q-Switch/LHR types — see types/index.ts SessionTypeDef and
    // components/settings/MachineTypeFormModal.tsx.
    match /sessionTypeDefs/{sessionTypeDefId} {
      allow read: if belongsToClinic(resource.data);
      allow create: if belongsToClinic(request.resource.data);
      allow update: if belongsToClinic(resource.data)
        && belongsToClinic(request.resource.data);
      allow delete: if belongsToClinic(resource.data);
    }

    // Before/after photo metadata — see types/index.ts PatientPhoto. The
    // actual image bytes live in Firebase Storage (see storage.rules);
    // this is just the per-photo record (who took it, which visit, the
    // download URL, the sensitive flag).
    match /patientPhotos/{photoId} {
      allow read: if belongsToClinic(resource.data);
      allow create: if belongsToClinic(request.resource.data);
      allow update: if belongsToClinic(resource.data)
        && belongsToClinic(request.resource.data);
      allow delete: if belongsToClinic(resource.data);
    }

    // Clinic-authored consent form templates — see types/index.ts
    // ConsentFormTemplate and components/settings/ConsentTemplateFormModal.tsx.
    match /consentFormTemplates/{templateId} {
      allow read: if belongsToClinic(resource.data);
      allow create: if belongsToClinic(request.resource.data);
      allow update: if belongsToClinic(resource.data)
        && belongsToClinic(request.resource.data);
      allow delete: if belongsToClinic(resource.data);
    }

    // Signed consent forms — see types/index.ts ConsentForm. Deliberately no
    // update rule: once signed, a consent record shouldn't be editable, only
    // created or removed (e.g. if logged in error). The signature image
    // itself lives in Firebase Storage — see storage.rules.
    match /consentForms/{consentFormId} {
      allow read: if belongsToClinic(resource.data);
      allow create: if belongsToClinic(request.resource.data);
      allow delete: if belongsToClinic(resource.data);
    }

    // Patient-wise receipts, generated from the Documents section — see
    // types/index.ts Receipt. No update rule: once issued a receipt is
    // immutable, only created or removed (e.g. if issued in error) — same
    // reasoning as consentForms above. receiptNumber is allocated from the
    // counters collection below before this document is written.
    match /receipts/{receiptId} {
      allow read: if belongsToClinic(resource.data);
      allow create: if belongsToClinic(request.resource.data);
      allow delete: if belongsToClinic(resource.data);
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
